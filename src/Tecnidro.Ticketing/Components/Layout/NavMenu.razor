@implements IDisposable

@inject NavigationManager NavigationManager

<div class="brand-panel">
    <div class="brand-mark">T</div>
    <div>
        <MudText Typo="Typo.subtitle1">Tecnidro SRL</MudText>
        <MudText Typo="Typo.caption">Sistema interno</MudText>
    </div>
</div>

<MudNavMenu Class="main-nav">
    <MudNavLink Href="" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">Dashboard</MudNavLink>
    <MudNavLink Href="tickets" Icon="@Icons.Material.Filled.ConfirmationNumber">Tickets</MudNavLink>

    <AuthorizeView>
        <Authorized>
            <MudNavLink Href="Account/Manage" Icon="@Icons.Material.Filled.ManageAccounts">Mi cuenta</MudNavLink>
            <form action="Account/Logout" method="post" class="logout-form">
                <AntiforgeryToken />
                <input type="hidden" name="ReturnUrl" value="@currentUrl" />
                <MudButton ButtonType="ButtonType.Submit" StartIcon="@Icons.Material.Filled.Logout" Variant="Variant.Text" Color="Color.Inherit" FullWidth="true">
                    Salir
                </MudButton>
            </form>
        </Authorized>
        <NotAuthorized>
            <MudNavLink Href="Account/Register" Icon="@Icons.Material.Filled.PersonAdd">Registro</MudNavLink>
            <MudNavLink Href="Account/Login" Icon="@Icons.Material.Filled.Login">Login</MudNavLink>
        </NotAuthorized>
    </AuthorizeView>
</MudNavMenu>

@code {
    private string? currentUrl;

    protected override void OnInitialized()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        StateHasChanged();
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
