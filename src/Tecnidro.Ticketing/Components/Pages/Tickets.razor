@page "/tickets"
@rendermode InteractiveServer
@inject TicketWorkspaceService TicketWorkspace
@inject OutlookMailboxService OutlookMailbox
@inject ISnackbar Snackbar

<PageTitle>Tickets | Tecnidro Ticketing</PageTitle>

<MudPopoverProvider />
<MudSnackbarProvider />

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="page-heading">
        <div>
            <MudText Typo="Typo.h4">Tickets</MudText>
            <MudText Typo="Typo.body1" Color="Color.Secondary">Bandeja de trabajo creada a partir de correos Outlook/Microsoft 365.</MudText>
        </div>
        <MudButton Variant="Variant.Outlined"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Sync"
                   Disabled="_syncing"
                   OnClick="SyncOutlookAsync">
            @(_syncing ? "Sincronizando..." : "Sincronizar Outlook")
        </MudButton>
    </MudStack>

    @if (!_mailboxConfigured)
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
            Outlook todavia no esta configurado. Carga TenantId, ClientId, ClientSecret y MailboxAddress con user-secrets para poder crear tickets desde emails reales.
        </MudAlert>
    }

    @if (!string.IsNullOrWhiteSpace(_syncMessage))
    {
        <MudAlert Severity="_syncSeverity" Variant="Variant.Outlined">
            @_syncMessage
        </MudAlert>
    }

    <MudGrid Spacing="3">
        <MudItem xs="12" lg="8">
            <MudPaper Class="work-surface" Elevation="0">
                <MudStack Row="true"
                          AlignItems="AlignItems.Center"
                          Justify="Justify.SpaceBetween"
                          Class="mb-3"
                          Style="gap: 12px; flex-wrap: wrap;">
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        @_selectedTicketIds.Count seleccionados
                    </MudText>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Style="gap: 8px; flex-wrap: wrap;">
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Primary"
                                   Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.SelectAll"
                                   Disabled="_tickets.Count == 0"
                                   OnClick="SelectAllTickets">
                            Seleccionar todos
                        </MudButton>
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Default"
                                   Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Deselect"
                                   Disabled="_selectedTicketIds.Count == 0"
                                   OnClick="ClearTicketSelection">
                            Limpiar seleccion
                        </MudButton>
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Error"
                                   Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Delete"
                                   Disabled="_selectedTicketIds.Count == 0 || _deletingTickets"
                                   OnClick="RequestDeleteSelectedTickets">
                            Eliminar seleccionados
                        </MudButton>
                    </MudStack>
                </MudStack>

                @if (_confirmingDelete)
                {
                    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mb-3">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Style="gap: 12px; flex-wrap: wrap;">
                            <MudText Typo="Typo.body2">
                                Vas a eliminar @_selectedTicketIds.Count ticket(s). Esta accion tambien borra historial y logs asociados.
                            </MudText>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Style="gap: 8px;">
                                <MudButton Variant="Variant.Text"
                                           Color="Color.Default"
                                           Size="Size.Small"
                                           Disabled="_deletingTickets"
                                           OnClick="CancelDeleteSelectedTickets">
                                    Cancelar
                                </MudButton>
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Error"
                                           Size="Size.Small"
                                           StartIcon="@Icons.Material.Filled.DeleteForever"
                                           Disabled="_deletingTickets"
                                           OnClick="DeleteSelectedTicketsAsync">
                                    @(_deletingTickets ? "Eliminando..." : "Confirmar")
                                </MudButton>
                            </MudStack>
                        </MudStack>
                    </MudAlert>
                }

                <MudTable Items="_tickets" Hover="true" Dense="true" Breakpoint="Breakpoint.Sm" Class="ticket-table" RowClassFunc="SelectedRowClass">
                    <HeaderContent>
                        <MudTh></MudTh>
                        <MudTh>Numero</MudTh>
                        <MudTh>Cliente</MudTh>
                        <MudTh>Asunto</MudTh>
                        <MudTh>Prioridad</MudTh>
                        <MudTh>Estado</MudTh>
                        <MudTh></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Seleccionar">
                            <MudCheckBox T="bool"
                                         Value="@_selectedTicketIds.Contains(context.Id)"
                                         ValueChanged="@((bool value) => ToggleTicketSelection(context.Id, value))"
                                         Color="Color.Primary"
                                         Dense="true" />
                        </MudTd>
                        <MudTd DataLabel="Numero">@context.Numero</MudTd>
                        <MudTd DataLabel="Cliente">@context.NombreCliente</MudTd>
                        <MudTd DataLabel="Asunto">@context.Asunto</MudTd>
                        <MudTd DataLabel="Prioridad">
                            <MudChip T="string" Size="Size.Small" Color="@PriorityColor(context.Prioridad)">@context.Prioridad</MudChip>
                        </MudTd>
                        <MudTd DataLabel="Estado">
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="@StatusColor(context.Estado)">@context.Estado</MudChip>
                        </MudTd>
                        <MudTd>
                            <MudTooltip Text="Abrir detalle">
                                <MudIconButton Icon="@Icons.Material.Filled.ChevronRight" Color="Color.Primary" OnClick="@(() => SelectTicket(context))" />
                            </MudTooltip>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" lg="4">
            @if (_selectedTicket is null)
            {
                <MudPaper Class="detail-panel empty-detail" Elevation="0">
                    <MudIcon Icon="@Icons.Material.Filled.ConfirmationNumber" Size="Size.Large" Color="Color.Primary" />
                    <MudText Typo="Typo.h6">Selecciona un ticket</MudText>
                    <MudText Typo="Typo.body2">El detalle, historial y cierre apareceran aqui. Si la lista esta vacia, sincroniza Outlook.</MudText>
                </MudPaper>
            }
            else
            {
                <MudPaper Class="detail-panel" Elevation="0">
                    <MudStack Spacing="3">
                        <MudStack Row="true" AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween">
                            <div>
                                <MudText Typo="Typo.overline">@_selectedTicket.Numero</MudText>
                                <MudText Typo="Typo.h6">@_selectedTicket.Asunto</MudText>
                            </div>
                            <MudChip T="string" Size="Size.Small" Color="@StatusColor(_selectedTicket.Estado)">@_selectedTicket.Estado</MudChip>
                        </MudStack>

                        <MudDivider />

                        <MudStack Spacing="1">
                            <MudText Typo="Typo.subtitle2">Cliente</MudText>
                            <MudText Typo="Typo.body2">@_selectedTicket.NombreCliente</MudText>
                            <MudText Typo="Typo.body2">@_selectedTicket.EmailCliente</MudText>
                        </MudStack>

                        <MudStack Spacing="1">
                            <MudText Typo="Typo.subtitle2">Email original</MudText>
                            <MudText Typo="Typo.body2">@_selectedTicket.CuerpoOriginal</MudText>
                        </MudStack>

                        <MudStack Spacing="1">
                            <MudText Typo="Typo.subtitle2">Historial</MudText>
                            @if (_selectedTicket.Comentarios.Count == 0)
                            {
                                <MudText Typo="Typo.body2">Sin comentarios internos.</MudText>
                            }
                            else
                            {
                                @foreach (var comment in _selectedTicket.Comentarios)
                                {
                                    <MudPaper Class="history-item" Elevation="0">
                                        <MudText Typo="Typo.body2">@comment.Texto</MudText>
                                        <MudText Typo="Typo.caption">@comment.CreadoEn.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</MudText>
                                    </MudPaper>
                                }
                            }
                        </MudStack>

                        @if (_selectedTicket.Estado == TicketStatus.Cerrado)
                        {
                            <MudAlert Severity="Severity.Success" Variant="Variant.Outlined">
                                Ticket cerrado. Email de resolucion registrado para envio al cliente.
                            </MudAlert>
                        }
                        else
                        {
                            <MudTextField @bind-Value="_resolutionText"
                                          Label="Resolucion para el cliente"
                                          Lines="5"
                                          Variant="Variant.Outlined"
                                          Required="true"
                                          Immediate="true" />
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.TaskAlt"
                                       OnClick="CloseSelectedTicket">
                                Cerrar y preparar email
                            </MudButton>
                        }
                    </MudStack>
                </MudPaper>
            }
        </MudItem>
    </MudGrid>
</MudStack>

@code {
    private IReadOnlyList<Ticket> _tickets = [];
    private Ticket? _selectedTicket;
    private string _resolutionText = string.Empty;
    private readonly HashSet<int> _selectedTicketIds = [];
    private bool _syncing;
    private bool _deletingTickets;
    private bool _confirmingDelete;
    private bool _mailboxConfigured;
    private string? _syncMessage;
    private Severity _syncSeverity = Severity.Info;

    protected override async Task OnInitializedAsync()
    {
        _mailboxConfigured = OutlookMailbox.IsConfigured;
        await ReloadTicketsAsync();
    }

    private async Task ReloadTicketsAsync()
    {
        _tickets = await TicketWorkspace.GetTicketsAsync();
        _selectedTicketIds.RemoveWhere(id => _tickets.All(ticket => ticket.Id != id));
        _selectedTicket = _selectedTicket is null
            ? _tickets.FirstOrDefault()
            : _tickets.FirstOrDefault(ticket => ticket.Id == _selectedTicket.Id) ?? _tickets.FirstOrDefault();
        _resolutionText = _selectedTicket?.ResolucionTexto ?? string.Empty;

        if (_selectedTicketIds.Count == 0)
        {
            _confirmingDelete = false;
        }
    }

    private void SelectTicket(Ticket ticket)
    {
        _selectedTicket = ticket;
        _resolutionText = ticket.ResolucionTexto ?? string.Empty;
    }

    private void ToggleTicketSelection(int ticketId, bool selected)
    {
        if (selected)
        {
            _selectedTicketIds.Add(ticketId);
        }
        else
        {
            _selectedTicketIds.Remove(ticketId);
        }

        if (_selectedTicketIds.Count == 0)
        {
            _confirmingDelete = false;
        }
    }

    private void SelectAllTickets()
    {
        foreach (var ticket in _tickets)
        {
            _selectedTicketIds.Add(ticket.Id);
        }
    }

    private void ClearTicketSelection()
    {
        _selectedTicketIds.Clear();
        _confirmingDelete = false;
    }

    private void RequestDeleteSelectedTickets()
    {
        if (_selectedTicketIds.Count > 0)
        {
            _confirmingDelete = true;
        }
    }

    private void CancelDeleteSelectedTickets()
    {
        _confirmingDelete = false;
    }

    private async Task DeleteSelectedTicketsAsync()
    {
        if (_selectedTicketIds.Count == 0)
        {
            return;
        }

        _deletingTickets = true;

        try
        {
            var idsToDelete = _selectedTicketIds.ToArray();
            var deletedCount = await TicketWorkspace.DeleteTicketsAsync(idsToDelete);

            _selectedTicketIds.Clear();
            _confirmingDelete = false;
            await ReloadTicketsAsync();

            Snackbar.Add($"{deletedCount} ticket(s) eliminados.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error eliminando tickets: {ex.Message}", Severity.Error);
        }
        finally
        {
            _deletingTickets = false;
        }
    }

    private async Task CloseSelectedTicket()
    {
        if (_selectedTicket is null)
        {
            return;
        }

        try
        {
            _selectedTicket = await TicketWorkspace.CloseTicketAsync(_selectedTicket.Id, _resolutionText);
            _tickets = await TicketWorkspace.GetTicketsAsync();
            Snackbar.Add("Ticket cerrado y email saliente registrado.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task SyncOutlookAsync()
    {
        _syncing = true;

        try
        {
            var result = await OutlookMailbox.SyncUnreadInboxAsync();
            await ReloadTicketsAsync();

            _syncSeverity = result.Created > 0 ? Severity.Success : Severity.Info;
            _syncMessage = result.Message;
            Snackbar.Add(result.Message, _syncSeverity);
        }
        catch (Exception ex)
        {
            _syncSeverity = Severity.Error;
            _syncMessage = $"Error sincronizando Outlook: {ex.Message}";
            Snackbar.Add(_syncMessage, Severity.Error);
        }
        finally
        {
            _syncing = false;
        }
    }

    private string SelectedRowClass(Ticket ticket, int rowNumber)
    {
        return _selectedTicket?.Id == ticket.Id ? "selected-ticket-row" : string.Empty;
    }

    private static Color PriorityColor(TicketPriority priority) => priority switch
    {
        TicketPriority.Urgente => Color.Error,
        TicketPriority.Alta => Color.Warning,
        TicketPriority.Normal => Color.Info,
        _ => Color.Default
    };

    private static Color StatusColor(TicketStatus status) => status switch
    {
        TicketStatus.Cerrado => Color.Success,
        TicketStatus.EnProgreso => Color.Info,
        TicketStatus.Asignado => Color.Warning,
        _ => Color.Primary
    };
}
